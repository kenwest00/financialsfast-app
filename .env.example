# FinancialsFast — Environment Variables
# Copy to .env.local and fill in values

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Stripe Price ID (create product in Stripe Dashboard first)
# Product: "P&L Statement Generator" — $125.00 USD, one-time
STRIPE_PRICE_ID=your_stripe_price_id_here

# Public keys (accessible in browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Production overrides (set in Vercel Dashboard):
# NEXT_PUBLIC_BASE_URL=https://financialsfast.com
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
